{
  "name": "project-valkyrie",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm-run-all --parallel -l dev:backend dev:frontend",
    "dev:backend": "convex dev",
    "dev:frontend": "next dev --port 3000",
    "predev": "convex dev --until-success",
    "build": "next build",
    "start": "next start --port 3000",
    "lint": "eslint"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@clerk/nextjs": "^7.0.4",
    "@clerk/themes": "^2.4.57",
    "convex": "^1.33.1",
    "next": "16.1.7",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
